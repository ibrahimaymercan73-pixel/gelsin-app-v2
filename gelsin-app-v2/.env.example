# Supabase – SADECE "anon public" key kullanın. Service Role key KULLANMAYIN (403 hatası verir).
# Dashboard: https://supabase.com/dashboard → Projeniz → Project Settings → API
# "anon" / "public" key'i kopyalayın.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....anon_key_buraya

# Sunucu tarafı (API routes): Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# İleti Merkezi SMS API v1 (telefon ile giriş) — https://www.iletimerkezi.com/sms-api
ILETIMERKEZI_KEY=7c39fd074d2240b201eef87a53fd4a69
ILETIMERKEZI_HASH=b521e2e8182f81db6d3c494e8f7927fa7b44ec367d1086addac0eb6972446f41
ILETIMERKEZI_SENDER=APITEST
# İYS: ticari gönderimde 1 + BIREYSEL veya TACIR. OTP için çoğu senaryoda 0 yeterlidir.
# ILETIMERKEZI_IYS=0
# ILETIMERKEZI_IYS_LIST=BIREYSEL

# Google AI (Gemini) — Pro işlerde aşama fotoğraf denetimi (/api/ai/check-milestone)
# Yoksa veya API hata verirse: yedek akışta aşama otomatik onaylanır (kullanıcıya uyarı gösterilir).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opsiyonel; boşsa gemini-2.0-flash kullanılır (örn. gemini-2.0-flash, gemini-1.5-flash-latest)
# GEMINI_MODEL=

# (Opsiyonel) Prisma ile OtpCode modeli: prisma/schema.prisma
# DATABASE_URL=postgresql://...
