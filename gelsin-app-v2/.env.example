# Supabase – SADECE "anon public" key kullanın. Service Role key KULLANMAYIN (403 hatası verir).
# Dashboard: https://supabase.com/dashboard → Projeniz → Project Settings → API
# "anon" / "public" key'i kopyalayın.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....anon_key_buraya

# Sunucu tarafı (API routes): Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Netgsm SMS (telefon ile giriş) — https://www.netgsm.com.tr
NETGSM_USER=
NETGSM_PASS=
NETGSM_TITLE=
